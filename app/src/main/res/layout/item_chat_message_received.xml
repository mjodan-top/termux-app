<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="8dp"
    android:paddingVertical="2dp">

    <LinearLayout
        android:id="@+id/chat_received_bubble"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:background="@drawable/chat_bubble_received"
        android:padding="8dp"
        android:layout_marginEnd="48dp"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="2dp">

        <TextView
            android:id="@+id/chat_received_sender_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FF81D4FA"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginBottom="2dp" />

        <TextView
            android:id="@+id/chat_received_message_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFFFF"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/chat_received_time_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:textColor="#CCFFFFFF"
            android:textSize="10sp"
            android:layout_marginTop="2dp" />

    </LinearLayout>

</FrameLayout>
